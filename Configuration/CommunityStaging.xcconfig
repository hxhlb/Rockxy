// CommunityStaging.xcconfig — Staging/beta channel for release candidates.
// Same release identity as production — promotes the same build without rebuilding.

#include "CommunityBase.xcconfig"

ROCKXY_RELEASE_CHANNEL = community-stag
ROCKXY_UPDATES_ENABLED = YES
ROCKXY_SPARKLE_FEED_URL = $(ROCKXY_PUBLIC_APPCAST_FEED_URL)
ROCKXY_BUILD_RELEASE_DATE = $(ROCKXY_RELEASE_BUILD_DATE)
