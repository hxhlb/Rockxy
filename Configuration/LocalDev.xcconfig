// LocalDev.xcconfig — Local development configuration.
// Uses release identity so dev builds can communicate with the helper
// without full identity isolation.

#include "CommunityBase.xcconfig"

ROCKXY_RELEASE_CHANNEL = local-dev
ROCKXY_UPDATES_ENABLED = NO
ROCKXY_SPARKLE_FEED_URL = $(ROCKXY_PUBLIC_APPCAST_FEED_URL)
